<configuration>

    <!-- ============================================================
         TassMUD Logging Configuration (Logback)
         
         Log files:
           logs/server.log   — All INFO+ messages (main operational log)
           logs/server.err   — WARN and ERROR only (actual problems)
           logs/spawn.log    — SpawnEvent/SpawnEventLogger messages only
         
         Console (stdout):
           INFO+ summary for dev use
         ============================================================ -->

    <property name="LOG_DIR" value="logs" />
    <property name="PATTERN" value="%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n" />

    <!-- === Console appender (stdout, not stderr) === -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.out</target>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- === server.log — all INFO+ messages === -->
    <appender name="SERVER_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/server.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- === server.err — WARN/ERROR only === -->
    <appender name="SERVER_ERR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/server.err</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/server.%d{yyyy-MM-dd}.%i.err</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- === spawn.log — SpawnEvent messages only === -->
    <appender name="SPAWN_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/spawn.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/spawn.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>3</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- === Logger: SpawnEventLogger → spawn.log only (not server.log/err) === -->
    <logger name="com.example.tassmud.util.SpawnEventLogger" level="INFO" additivity="false">
        <appender-ref ref="SPAWN_LOG" />
    </logger>

    <!-- === Logger: SpawnEvent → spawn.log only === -->
    <logger name="com.example.tassmud.event.SpawnEvent" level="INFO" additivity="false">
        <appender-ref ref="SPAWN_LOG" />
    </logger>

    <!-- === Logger: SpawnManager → spawn.log only === -->
    <logger name="com.example.tassmud.event.SpawnManager" level="INFO" additivity="false">
        <appender-ref ref="SPAWN_LOG" />
    </logger>

    <!-- === H2 driver noise — suppress === -->
    <logger name="org.h2" level="WARN" />

    <!-- === Root logger: INFO+ to console, server.log, server.err === -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="SERVER_LOG" />
        <appender-ref ref="SERVER_ERR" />
    </root>

</configuration>
